@model List<MVCDemo.Models.employee>
@* @model IEnumerable<MVCDemo.Models.employee> *@
@{
    ViewData["Title"] = "collectionofobjectpassing";
}
<style>
	table {
		align-content: center;
		align-items: center;
		border-collapse: collapse;
		width: 50%;
	}

	table, th, td {
		border: 2px solid black;
	}

	th, td {
		padding: 8px;
		text-align: left;
	}
</style>

<h1>collectionofobjectpassing</h1>
<table>
	<thead>
		<tr>
			<th>EmployeeID</th>
			<th>EmpName</th>
			<th>Salary</th>
			<th>Image</th>
			<th>Link</th>
		</tr>
	</thead>
	<tbody>
		@foreach(var emp in Model)
		{
			<tr>
				<td>@emp.empId</td>
				<td>@emp.empName</td>
				<td>@emp.salary</td>
				<td>
					<img src="@emp.imageurl" alt="@emp.empName" width="100" height="100" />
				</td>
				<td>
                    <a href="/Home/Details/@emp.empId">Details</a>
					 | <a asp-controller="Home" asp-action="Details" asp-route-id="@emp.empId">Details</a>

				</td>
			</tr>
		}
	</tbody>
</table>
