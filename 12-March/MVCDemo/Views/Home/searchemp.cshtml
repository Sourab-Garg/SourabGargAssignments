@Model MVCDemo.Models.employee;
@{
    ViewData["Title"] = "searchemp";
}

<style>
    h1 {
        color: #333;
        text-align: center;
        margin-bottom: 30px;
    }

    table {
        width: 100%;
        max-width: 800px;
        margin: 0 auto;
        border-collapse: collapse;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
        background-color: #fff;
    }

    th {
        background-color: #007bff;
        color: white;
        padding: 15px;
        text-align: left;
        font-weight: bold;
        border: 1px solid #0056b3;
    }

    td {
        padding: 12px 15px;
        border: 1px solid #ddd;
        color: #333;
    }

    tr:hover {
        background-color: #f5f5f5;
    }

    img {
        border-radius: 4px;
        display: block;
    }
</style>

<h1>searchemp</h1>

<table border="1" cellpadding="2" cellspacing="3">
    <tr>
        <th>EmployeeID</th>
        <th>EmpName</th>
        <th>Salary</th>
        <th>Image</th>
    </tr>
    <tr>
        <td>@Model.empId</td>
        <td>@Model.empName</td>
        <td>@Model.salary</td

        <td>
            <img src="@Model.imageurl" alt="@Model.empName" width="100" height="100" />
        </td>
    </tr>
</table>