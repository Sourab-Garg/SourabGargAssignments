@model List<MVCDemo.Models.employee>
@{
    ViewData["Title"] = "Employees by Department";
}

<style>
    .container {
        max-width: 1000px;
        margin: 30px auto;
        font-family: Arial, sans-serif;
        padding: 20px;
    }

    .header-section {
        background-color: #e7f3ff;
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 30px;
        border-left: 4px solid #007bff;
    }

    .header-section h1 {
        color: #007bff;
        margin: 0 0 10px 0;
    }

    .header-section p {
        color: #555;
        margin: 5px 0;
    }

    .back-link {
        display: inline-block;
        margin-bottom: 20px;
        padding: 8px 16px;
        background-color: #6c757d;
        color: white;
        text-decoration: none;
        border-radius: 4px;
        transition: background-color 0.3s;
    }

    .back-link:hover {
        background-color: #5a6268;
    }

    .emp-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 20px;
        margin-top: 30px;
    }

    .emp-card {
        background-color: #f5f5f5;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .emp-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0,0,0,0.2);
    }

    .emp-image {
        width: 100%;
        height: 200px;
        overflow: hidden;
        background-color: #e0e0e0;
    }

    .emp-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .emp-info {
        padding: 20px;
    }

    .emp-name {
        font-size: 18px;
        font-weight: bold;
        color: #333;
        margin-bottom: 10px;
    }

    .emp-detail {
        color: #666;
        margin: 8px 0;
        font-size: 14px;
    }

    .emp-detail strong {
        color: #333;
    }

    .details-link {
        display: inline-block;
        margin-top: 15px;
        padding: 8px 16px;
        background-color: #007bff;
        color: white;
        text-decoration: none;
        border-radius: 4px;
        font-size: 14px;
        transition: background-color 0.3s;
    }

    .details-link:hover {
        background-color: #0056b3;
    }

    .no-employees {
        text-align: center;
        padding: 40px;
        color: #999;
        font-size: 18px;
    }
</style>

<div class="container">
    <a class="back-link" asp-action="ViewDepartments">← Back to Departments</a>

    <div class="header-section">
        <h1>@ViewBag.DepartmentName</h1>
        <p><strong>Department ID:</strong> @ViewBag.DepartmentId</p>
        <p><strong>Total Employees:</strong> @(Model?.Count ?? 0)</p>
    </div>

    @if (Model != null && Model.Count > 0)
    {
        <div class="emp-grid">
            @foreach (var emp in Model)
            {
                <div class="emp-card">
                    <div class="emp-image">
                        <img src="@emp.imageurl" alt="@emp.empName" />
                    </div>
                    <div class="emp-info">
                        <div class="emp-name">@emp.empName</div>
                        <div class="emp-detail">
                            <strong>ID:</strong> @emp.empId
                        </div>
                        <div class="emp-detail">
                            <strong>Salary:</strong> $@emp.salary.ToString("N0")
                        </div>
                        <a class="details-link" asp-action="Details" asp-route-id="@emp.empId">
                            View Details
                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="no-employees">
            <p>No employees found in this department.</p>
        </div>
    }
</div>
