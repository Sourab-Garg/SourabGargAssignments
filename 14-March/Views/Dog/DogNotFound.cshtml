@model int

@{
    ViewData["Title"] = "Dog Not Found";
}

<style>
    .container {
        max-width: 600px;
        margin: 60px auto;
        padding: 40px;
        text-align: center;
        font-family: Arial, sans-serif;
    }

    h1 {
        color: #dc3545;
        font-size: 36px;
        margin-bottom: 15px;
    }

    .not-found-message {
        background-color: #f8d7da;
        color: #721c24;
        padding: 20px;
        border-radius: 8px;
        margin-bottom: 30px;
    }

    .action-links {
        display: flex;
        gap: 15px;
        justify-content: center;
    }

    .btn {
        padding: 12px 25px;
        border-radius: 6px;
        text-decoration: none;
        font-weight: bold;
    }

    .btn-primary {
        background-color: #007bff;
        color: white;
    }

    .btn-secondary {
        background-color: #6c757d;
        color: white;
    }

    .btn-success {
        background-color: #28a745;
        color: white;
    }

    .btn:hover {
        opacity: 0.9;
        text-decoration: none;
        color: white;
    }
</style>

<div class="container">
    <h1>Dog Not Found</h1>
    <div class="not-found-message">
        <p>No dog found with ID: <strong>@Model</strong></p>
    </div>
    <div class="action-links">
        <a class="btn btn-primary" asp-controller="Dog" asp-action="Index">View All Dogs</a>
        <a class="btn btn-success" asp-controller="Dog" asp-action="Create">+ Add Dog</a>
        <a class="btn btn-secondary" asp-controller="Home" asp-action="Index">Back to Home</a>
    </div>
</div>